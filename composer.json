{
    "name": "rankbeam/laravel-seo-filament",
    "description": "Filament 4/5 form components for the Rankbeam Laravel SEO core - SEO section with live character counters, search-snippet preview, and manual-vs-fallback indicators.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "filament",
        "seo",
        "meta-tags",
        "filament-plugin"
    ],
    "authors": [
        {
            "name": "Valentin Goxhaj",
            "email": "valentinogoxhaj@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "rankbeam/laravel-seo": "^2.0",
        "filament/filament": "^4.0|^5.0"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../laravel-seo",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "Rankbeam\\Seo\\Filament\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rankbeam\\Seo\\Filament\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.x-dev"
        },
        "laravel": {
            "providers": [
                "Rankbeam\\Seo\\Filament\\SeoFilamentServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "vendor/bin/pest",
        "format": "vendor/bin/pint"
    }
}
